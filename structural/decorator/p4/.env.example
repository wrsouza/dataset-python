# Região AWS usada pelos clientes boto3 (CloudWatch Metrics e Logs)
AWS_REGION=us-east-1

# Credenciais AWS (use perfis/roles em produção; aqui apenas para dev local)
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme

# Namespace usado para métricas customizadas no CloudWatch
CLOUDWATCH_METRICS_NAMESPACE=ObservabilityDecorator/Orders

# Log group usado para exportar spans de tracing no CloudWatch Logs
CLOUDWATCH_LOG_GROUP=/observability-decorator/traces
