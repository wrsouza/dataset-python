# Messaging Protocol Adapter — P5 environment variables
# Copy this file to .env and adjust as needed.

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=app
RABBITMQ_PASSWORD=secret
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Tests ─────────────────────────────────────────────────────────────────────
# Set to "true" to run integration tests against real brokers
RUN_INTEGRATION=false
