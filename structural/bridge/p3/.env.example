# ── Queue Bridge — Environment Variables ──────────────────────────────────────
# Copy to .env and adjust as needed.

# Django
DJANGO_SECRET_KEY=dev-only-insecure-key-change-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# Celery / Redis (CeleryRedisBroker)
REDIS_URL=redis://redis:6379/0

# RabbitMQ (RabbitMQBroker, via pika)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# AWS SQS (SQSBroker, via boto3) — points at LocalStack by default
AWS_ENDPOINT_URL=http://localstack:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
