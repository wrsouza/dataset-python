# Notification Bridge — environment variables
# Copy to .env and adjust for your environment.

# LocalStack endpoint (use http://localhost:4566 outside Docker)
LOCALSTACK_ENDPOINT=http://localstack:4566

# AWS credentials (LocalStack accepts any values)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# SES sender address (must be verified in LocalStack)
SES_SENDER=noreply@example.com
