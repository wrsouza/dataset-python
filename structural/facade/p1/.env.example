# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=appdb

# SQLAlchemy connection string consumed by order.infrastructure.database
DATABASE_URL=postgresql://app:secret@db:5432/appdb

# ── AWS SQS (SQSNotificationService) — points at LocalStack by default ───────
SQS_QUEUE_URL=http://localstack:4566/000000000000/orders
AWS_ENDPOINT_URL=http://localstack:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
