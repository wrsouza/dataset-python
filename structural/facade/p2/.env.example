# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_USER=app
MYSQL_PASSWORD=secret
MYSQL_DATABASE=appdb
MYSQL_ROOT_PASSWORD=rootsecret

# SQLAlchemy connection string consumed by payment.infrastructure.database
DATABASE_URL=mysql+pymysql://app:secret@db:3306/appdb

# ── Stripe ────────────────────────────────────────────────────────────────────
# Set USE_MOCK_STRIPE=false and provide a real Stripe test-mode secret key
# (sk_test_...) to exercise the real Stripe SDK instead of MockStripeGateway.
USE_MOCK_STRIPE=true
STRIPE_API_KEY=sk_test_placeholder

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
