# Glyph Font Renderer — variáveis de ambiente
# Não há serviço externo (banco de dados ou API); todas as configurações
# abaixo controlam apenas a aplicação Streamlit local.

# Porta exposta pelo servidor Streamlit
STREAMLIT_SERVER_PORT=8501

# Endereço de bind do servidor Streamlit
STREAMLIT_SERVER_ADDRESS=0.0.0.0
