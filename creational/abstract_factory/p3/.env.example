# Message Broker Factory — Environment Variables
# Copy to .env before running: cp .env.example .env

# ── Broker selection ────────────────────────────────────────────────────────
# Used by the CLI default (--broker can still override per command)
DEFAULT_BROKER=rabbitmq

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=app
RABBITMQ_PASSWORD=secret
RABBITMQ_URL=amqp://app:secret@rabbitmq:5672/

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── AWS SQS (via LocalStack) ─────────────────────────────────────────────────
LOCALSTACK_URL=http://localstack:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
