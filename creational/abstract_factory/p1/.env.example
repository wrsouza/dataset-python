# UI Component Factory — Environment Variables
# Copy to .env before running: cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=appdb

# Full DSN used by the Flask app (override for external DB)
DATABASE_URL=postgresql://app:secret@db:5432/appdb

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_APP=src/ui_factory/app.py
FLASK_ENV=development
FLASK_DEBUG=1
