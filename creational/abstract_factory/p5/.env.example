# ── Database Connector Factory — Environment Variables ────────────────────────
# Copy to .env and adjust as needed.

# Django
DJANGO_SECRET_KEY=dev-only-insecure-key-change-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL (default Django database + PostgreSQLFactory family)
POSTGRES_DB=appdb
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql://app:secret@postgres:5432/appdb

# MySQL (MySQLFactory family)
MYSQL_DATABASE=appdb
MYSQL_USER=app
MYSQL_PASSWORD=secret
MYSQL_HOST=mysql
MYSQL_PORT=3306

# SQL Server (SQLServerFactory family — optional, commented in docker-compose.yml)
SQLSERVER_DATABASE=appdb
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong@Passw0rd
SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433
