# Django
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Auth Provider Factory
JWT_SECRET=change-me-in-production

# OAuth (mocked — no real network calls are made in this educational example)
OAUTH_GOOGLE_CLIENT_ID=mock-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=mock-google-client-secret
OAUTH_GITHUB_CLIENT_ID=mock-github-client-id
OAUTH_GITHUB_CLIENT_SECRET=mock-github-client-secret
