DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Postgres (deixe vazio / use sqlite localmente se preferir)
DATABASE_URL=postgresql://app:secret@db:5432/email_builder_db
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=email_builder_db

# AWS SES (via LocalStack em dev)
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
