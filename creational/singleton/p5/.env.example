# ML Model Registry — variáveis de ambiente
# Não há banco de dados ou serviço externo; o registry vive em memória dentro
# do próprio processo Streamlit (Singleton por processo).

# Porta exposta pelo servidor Streamlit
STREAMLIT_SERVER_PORT=8501

# Endereço de bind do servidor Streamlit
STREAMLIT_SERVER_ADDRESS=0.0.0.0
