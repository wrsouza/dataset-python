# Chain of Responsibility — Request Validation Chain
# No environment variables are strictly required: the pipeline validates
# requests entirely in memory (no database, cache, or external API).
# Variables below are placeholders for future extension (e.g. swapping the
# in-memory rate limiter for a Redis-backed one).

# Uvicorn server settings (used only if you containerize differently)
APP_HOST=0.0.0.0
APP_PORT=8000

# Rate limit handler tuning (optional — defaults are hardcoded if unset)
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
